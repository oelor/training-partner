# Training Partner — Environment Variables
# Copy this file to .env.local and fill in the values

# API URL — Cloudflare Worker endpoint
NEXT_PUBLIC_API_URL=https://trainingpartner.app

# Site URL — used for redirects and metadata
NEXT_PUBLIC_SITE_URL=https://trainingpartner.app

# Google OAuth Client ID (from Google Cloud Console)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# Cloudflare Web Analytics beacon token (optional)
NEXT_PUBLIC_CF_BEACON_TOKEN=

# Cloudflare Turnstile site key (optional, for signup CAPTCHA)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
